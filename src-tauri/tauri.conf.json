{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Download Limit Controller",
  "version": "0.1.0",
  "identifier": "com.downloadlimit.controller",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:5188",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Download Limit Controller",
        "width": 1240,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
