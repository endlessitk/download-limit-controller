{
  "name": "download-limit-controller",
  "private": true,
  "version": "0.1.0",
  "description": "A Windows utility for managing per-app download limit rules.",
  "author": "Download Limit Controller",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "pnpm build && electron .",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "release": "pnpm release:electron",
    "release:electron": "pnpm build && electron-builder --win nsis --x64",
    "release:tauri": "tauri build --bundles nsis",
    "release:clean": "node -e \"const fs=require('fs'); for (const p of ['dist','release','src-tauri/target/release/bundle']) fs.rmSync(p,{recursive:true,force:true});\""
  },
  "dependencies": {
    "@tauri-apps/api": "^2.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^5.8.0",
    "vite": "^8.0.10"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.2.0",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.downloadlimit.controller",
    "productName": "Download Limit Controller",
    "copyright": "Copyright (c) 2026 Download Limit Controller",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "src-tauri/icons/icon.ico",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src-tauri/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Download Limit Controller",
      "uninstallDisplayName": "Download Limit Controller"
    }
  }
}
