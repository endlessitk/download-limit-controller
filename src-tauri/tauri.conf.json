{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Download Limit Controller",
  "version": "0.1.0",
  "identifier": "com.downloadlimit.controller",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:5188",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Download Limit Controller",
        "width": 1240,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Download Limit Controller",
    "category": "Utility",
    "copyright": "Copyright (c) 2026 Download Limit Controller",
    "shortDescription": "Per-app Windows download limit controller.",
    "longDescription": "A Windows utility for grouping active network apps by executable path and managing safe per-app download limit rules.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": ["English"],
        "displayLanguageSelector": false,
        "compression": "lzma",
        "startMenuFolder": "Download Limit Controller"
      }
    }
  }
}
